# ========== 老虎证券 Open API ==========
# 注册与凭证: https://quant.itigerup.com/#developer
# 需先在老虎开户、登记开发者，并开通 Open API 行情权限（实时行情需单独购买）

# 方式 A（推荐）：导出配置文件目录
# 将 tiger_openapi_config.properties 放到该目录；
# 港股牌照 TBHK 还需同目录放置 tiger_openapi_token.properties
# TIGER_PROPS_PATH=./tiger_config

# 方式 B：逐项填写（与方式 A 二选一）
TIGER_ID=20150001
TIGER_ACCOUNT=12345678
# 牌照: TBHK / TBSG / TBNZ / TBUS 等，见开发者页面
TIGER_LICENSE=TBHK
# PKCS#1 私钥 PEM 文件路径（勿提交到 git）
TIGER_PRIVATE_KEY_PATH=./secrets/private_key.pem
# 或直接填私钥内容（单行，不含头尾换行时可整段粘贴）
# TIGER_PRIVATE_KEY=MIICXgIBAAKBgQ...
# 机构账户才需要
# TIGER_SECRET_KEY=

# 是否连接沙箱环境（模拟）
TIGER_SANDBOX=false
# 本地监控列表上限（实际还受老虎行情套餐订阅数限制）
MAX_WATCHES=30

# ========== 飞书企业自建应用 ==========
# 开放平台: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 告警默认发送到的会话（chat_id）。可在飞书对话里发 /chatid 查询
FEISHU_ALERT_CHAT_ID=
FEISHU_ALERT_RECEIVE_ID_TYPE=chat_id

# 可选：群自定义机器人 Webhook（仅推送，不能收命令）
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ========== 服务 ==========
# HTTP 监听地址与端口（健康检查 GET / 或 /health）
HOST=0.0.0.0
PORT=8080

# ========== 监控默认值 ==========
DEFAULT_ALERT_PERCENT=2.0
ALERT_COOLDOWN_SECONDS=300

# ========== 数据与日志 ==========
DATA_FILE=./data/watches.json
LOG_LEVEL=INFO
