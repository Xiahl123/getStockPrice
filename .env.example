# ========== iTick ==========
# 在 https://itick.org 注册后获取 token
ITICK_TOKEN=your_itick_token_here
# 免费版: wss://api-free.itick.org/stock
# 付费版: wss://api.itick.org/stock
ITICK_WS_URL=wss://api-free.itick.org/stock
# 免费版最多同时订阅 3 只；付费可提高
ITICK_MAX_SUBSCRIPTIONS=3

# ========== 飞书企业自建应用 ==========
# 开放平台: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 告警默认发送到的会话（chat_id）。可在飞书对话里发 /chatid 查询
# 单聊也可使用用户 open_id（需把 FEISHU_ALERT_RECEIVE_ID_TYPE 改为 open_id）
FEISHU_ALERT_CHAT_ID=
FEISHU_ALERT_RECEIVE_ID_TYPE=chat_id

# 可选：群自定义机器人 Webhook（仅推送，不能收命令）。
# 若填写，告警会同时发到 Webhook。
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# ========== 监控默认值 ==========
# 相对当日开盘价涨跌幅度达到该百分比时提醒（可在飞书里按股票单独设置）
DEFAULT_ALERT_PERCENT=2.0
# 同一方向触发后的冷却秒数，避免刷屏
ALERT_COOLDOWN_SECONDS=300

# ========== 数据与日志 ==========
DATA_FILE=./data/watches.json
LOG_LEVEL=INFO
